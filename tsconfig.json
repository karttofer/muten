{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "types": ["node"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "paths": {
      "#engine/*": ["./src/engine/*"]
    },
    "rootDir": "src",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"]
}
